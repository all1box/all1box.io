{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.SignalR": "Information",
        "Microsoft.AspNetCore.Http.Connections": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "WebOSConn": "Server=YOUR_SERVER; Database=YOUR_DATABASE; User ID=YOUR_USER; Password=YOUR_PASSWORD; TrustServerCertificate=true; Connect Timeout=30;"
  },
  "WebOSSApi": {
    "BaseUrl": "https://YOUR_API_URL",
    "ApiKey": "YOUR_API_KEY"
  },
  "Twilio": {
    "AccountSid": "YOUR_ACCOUNT_SID",
    "AuthToken": "YOUR_AUTH_TOKEN",
    "FromNumber": "+1XXXXXXXXXX",
    "ToNumber": "+1XXXXXXXXXX"
  }
}
