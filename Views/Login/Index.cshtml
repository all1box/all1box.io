@{
    ViewData["Title"] = "Sign In";
    Layout = "_LoginLayout";
}

<main class="main" id="top">
    <div class="container">
        <div class="row flex-center min-vh-100 py-5">
            <div class="col-sm-10 col-md-8 col-lg-5 col-xl-4">
                <div class="card border">
                    <div class="card-body p-4 p-sm-5">
                        <form method="post" asp-controller="Login" asp-action="Index">
                            @Html.AntiForgeryToken()
                            <div class="mb-3 text-start">
                                <label class="form-label" for="login">Phone number or email</label>
                                <div class="form-icon-container">
                                    <input type="text" class="form-control form-icon-input" id="login" name="login"
                                           placeholder="alex@example.com" autocomplete="username" required autofocus />
                                    <span class="fas fa-user text-body fs-9 form-icon"></span>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-priclaudia w-100">Send verification code</button>
                        </form>

                        @if (ViewBag.Error != null)
                        {
                            <p class="text-danger mb-0 mt-4">@ViewBag.Error</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
